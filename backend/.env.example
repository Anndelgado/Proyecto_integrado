# Copia este archivo a ".env" (en la carpeta backend/) y ajusta la contraseña.
# Estos valores por defecto asumen un PostgreSQL NATIVO (no Docker) corriendo
# en el puerto estándar 5432.

PORT=4000

# Opción 1: una sola URL de conexión
DATABASE_URL=postgres://postgres:convive1234@localhost:5432/barranquilla_convive

# Opción 2 (alternativa): variables sueltas, se usan solo si no defines DATABASE_URL
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=TU_CONTRASEÑA
# PGDATABASE=barranquilla_convive

# Clave secreta para firmar los tokens de sesión. Genera la tuya con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA subas la clave real a un repositorio; este archivo es solo un ejemplo.
SESSION_SECRET=cambia_esto_por_una_clave_aleatoria_larga
